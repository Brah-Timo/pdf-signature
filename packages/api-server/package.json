{
  "name": "@pdf-signature/api-server",
  "version": "1.0.0",
  "description": "Fastify API server for pdf-signature — signing, verification, billing",
  "private": true,
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fastify": "^4.25.0",
    "@fastify/cors": "^8.4.0",
    "@fastify/helmet": "^11.1.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/multipart": "^8.0.0",
    "@fastify/jwt": "^8.0.0",
    "zod": "^3.22.0",
    "jsonwebtoken": "^9.0.0",
    "stripe": "^14.0.0",
    "resend": "^2.0.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@prisma/client": "^5.7.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "dotenv": "^16.3.0",
    "axios": "^1.6.0",
    "uuid": "^9.0.0",
    "maxmind": "^4.3.0",
    "@pdf-signature/crypto": "workspace:*",
    "@pdf-signature/pdf": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "ts-node-dev": "^2.0.0",
    "@types/node": "^20.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/uuid": "^9.0.0",
    "vitest": "^1.0.0",
    "prisma": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
