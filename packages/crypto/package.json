{
  "name": "@pdf-signature/crypto",
  "version": "1.0.0",
  "description": "Cryptographic engine for pdf-signature — PKCS#7, X.509, RFC 3161, SHA, RSA-PSS",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "node-forge": "^1.3.1",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsup": "^8.0.0",
    "vitest": "^1.0.0",
    "@types/node": "^20.0.0",
    "@types/node-forge": "^1.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
